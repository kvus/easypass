# EasyPass Server -- Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=easypass_user
DB_PASSWORD=easypass_pass
DB_NAME=easypass

# JWT
# IMPORTANT: Change this to a long random string in production!
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=1h
